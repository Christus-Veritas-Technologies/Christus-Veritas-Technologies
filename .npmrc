# Hoist all transitive dependencies to root node_modules.
# Required so @prisma/client-runtime-utils (a transitive dep of @prisma/client)
# is resolvable from the generated Prisma client at apps/hosts-demo/src/generated/prisma/.
# public-hoist-pattern only covers direct/peer deps; shamefully-hoist covers all transitives.
shamefully-hoist=true
