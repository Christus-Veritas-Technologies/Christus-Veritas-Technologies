{
  "name": "Christus-Veritas-Technologies",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @Christus-Veritas-Technologies/db db:push",
    "db:studio": "turbo -F @Christus-Veritas-Technologies/db db:studio",
    "db:generate": "turbo -F @Christus-Veritas-Technologies/db db:generate",
    "db:migrate": "turbo -F @Christus-Veritas-Technologies/db db:migrate"
  },
  "dependencies": {
    "@Christus-Veritas-Technologies/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@Christus-Veritas-Technologies/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.4.0"
}
